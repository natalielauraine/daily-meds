# ============================================================
# DAILY MEDS — .env.example
# ============================================================
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to GitHub.
# These are placeholder keys only — you need your own accounts
# for local development. Do not ask Natalie for her live keys.
# ============================================================

# ---------------------------
# Supabase
# ---------------------------
# Get from: supabase.com > Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------
# Stripe
# ---------------------------
# Get from: dashboard.stripe.com > Developers > API Keys
# Use TEST mode keys for local development (prefix: pk_test_ / sk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs — get from dashboard.stripe.com > Products
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_your-monthly-price-id
NEXT_PUBLIC_STRIPE_ANNUAL_PRICE_ID=price_your-annual-price-id
NEXT_PUBLIC_STRIPE_LIFETIME_PRICE_ID=price_your-lifetime-price-id

# ---------------------------
# Daily.co (Live rooms)
# ---------------------------
# Get from: dashboard.daily.co > Developers
DAILY_API_KEY=your-daily-api-key
NEXT_PUBLIC_DAILY_DOMAIN=your-subdomain.daily.co

# ---------------------------
# Vimeo (Video hosting)
# ---------------------------
# Get from: developer.vimeo.com > My Apps > Access Token
VIMEO_ACCESS_TOKEN=your-vimeo-access-token
NEXT_PUBLIC_VIMEO_ACCOUNT_ID=your-vimeo-account-id

# ---------------------------
# Resend (Transactional email)
# ---------------------------
# Get from: resend.com > API Keys
RESEND_API_KEY=re_your-resend-api-key

# ---------------------------
# Cloudflare R2 (Audio storage)
# ---------------------------
# Get from: dash.cloudflare.com > R2 > Manage API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=dailymeds
R2_PUBLIC_URL=https://your-r2-custom-domain.com

# ---------------------------
# App config
# ---------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Daily Meds

# ---------------------------
# Admin
# ---------------------------
# The email address that gets access to /admin routes
ADMIN_EMAIL=your-admin-email@example.com
