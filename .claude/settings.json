{
  "permissions": {
    "allow": [
      "Bash(npx next dev:*)",
      "Bash(npx next build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm install:*)",
      "Bash(node scripts/*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git merge:*)",
      "Bash(git push origin staging:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\":*)",
      "Bash(curl -s http://localhost:3001:*)",
      "Bash(openssl rand:*)",
      "Bash(pkill -f \"next dev\":*)",
      "Bash(pkill -f \"next-server\":*)"
    ],
    "deny": [
      "Bash(git push origin main:*)",
      "Bash(git push -f:*)"
    ]
  }
}
